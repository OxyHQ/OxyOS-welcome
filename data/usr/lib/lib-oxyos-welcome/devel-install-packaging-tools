DEVENV_TITLE=$"packaging tools"
DEVENV_TEXT=$"Would you like to install a suite of packages used for building .deb packages?"
DEVENV_PBUILDER=$"Create pbuilder environment now?"

if installPage "$DEVENV_TITLE" "$DEVENV_TEXT" 'oxyos-meta-packaging'; then
    echo 'MIRRORSITE=http://deb.debian.org/debian' | sudo tee '/etc/pbuilderrc'
    echo 'DISTRIBUTION=trixie' | sudo tee -a '/etc/pbuilderrc'
    echo 'COMPONENTS="main contrib non-free non-free-firmware"' >> sudo tee -a '/etc/pbuilderrc'

    prompt "  $DEVENV_PBUILDER" && sudo pbuilder create
fi
